# ── BACKEND ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.<your-ref>.supabase.co:5432/postgres
SUPABASE_URL=https://<your-ref>.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
# Get JWT Secret from: Supabase Dashboard > Settings > API > JWT Settings > JWT Secret
JWT_SECRET=your_jwt_secret
PORT=3000
NODE_ENV=development
RESCUEGROUPS_API_KEY=        # API key from rescuegroups.org (pulls from all Austin-area orgs)

# ── MOBILE (Expo public vars) ─────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=https://<your-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── OAUTH ─────────────────────────────────────────
# Google OAuth: Create credentials at https://console.cloud.google.com/apis/credentials
# Select "Web application" type. Add authorized redirect URI:
#   https://<your-ref>.supabase.co/auth/v1/callback
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth: Create app at https://developers.facebook.com
# Add Facebook Login product. Set Valid OAuth Redirect URI:
#   https://<your-ref>.supabase.co/auth/v1/callback
FACEBOOK_APP_ID=your_facebook_app_id
